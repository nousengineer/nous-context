# ==============================================================================
# ThinkCoffee - Environment Variables (V5 - Agent Safety Net)
# ==============================================================================
# Copie este arquivo para .env e configure conforme seu ambiente.
# NUNCA commite o arquivo .env no repositorio!
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------------------
NODE_ENV=production
THINKCOFFEE_VERSION=latest

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
MCP_PORT=3000
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Data Storage
# ------------------------------------------------------------------------------
THINKCOFFEE_DATA_DIR=/data
THINKCOFFEE_DB_PATH=/data/data.sqlite

# ------------------------------------------------------------------------------
# Agent Safety Net - Snapshot & Rollback
# ------------------------------------------------------------------------------
# Diretorio para snapshots de arquivos (backup antes de modificacoes)
THINKCOFFEE_SNAPSHOT_DIR=/data/snapshots

# Diretorio para logs de acoes de agentes (audit trail)
THINKCOFFEE_LOG_DIR=/data/logs

# Retencao de snapshots em dias (default: 7 para staging, 30 para production)
THINKCOFFEE_SNAPSHOT_RETENTION_DAYS=7

# Tamanho maximo de snapshot por pipeline em MB (default: 50)
THINKCOFFEE_SNAPSHOT_MAX_SIZE_MB=50

# ------------------------------------------------------------------------------
# Agent Safety Net - Dry-Run & Confirmacao
# ------------------------------------------------------------------------------
# Habilitar dry-run por padrao (true = agentes nao modificam arquivos)
THINKCOFFEE_DRY_RUN_DEFAULT=false

# Modo de diff preview: always | existing-only | never
# - always: mostra diff para TODA escrita (inclusive novos arquivos)
# - existing-only: mostra diff apenas para arquivos existentes (default)
# - never: grava direto sem preview
THINKCOFFEE_DIFF_PREVIEW_MODE=existing-only

# Confirmacao de comandos shell: always | destructive-only | never
# - always: pede confirmacao para QUALQUER comando
# - destructive-only: pede confirmacao apenas para comandos perigosos (default)
# - never: executa todos os comandos sem perguntar
THINKCOFFEE_COMMAND_CONFIRMATION=destructive-only

# ------------------------------------------------------------------------------
# Node.js Runtime
# ------------------------------------------------------------------------------
# Limite de memoria do Node.js (em MB)
# Staging: 256MB | Production: 512MB
NODE_OPTIONS=--max-old-space-size=256

# ------------------------------------------------------------------------------
# Backup Configuration
# ------------------------------------------------------------------------------
# Retencao de backups em dias
BACKUP_RETENTION_DAYS=30

# Numero maximo de backups mantidos
MAX_BACKUP_COUNT=10

# ------------------------------------------------------------------------------
# Deploy Configuration (usado pelo CI/CD)
# ------------------------------------------------------------------------------
# Host de deploy (SSH)
# DEPLOY_HOST=your-server.example.com
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY= # Configurar como secret no GitHub
# DEPLOY_URL=https://thinkcoffee.example.com

# ------------------------------------------------------------------------------
# Notificacoes
# ------------------------------------------------------------------------------
# Webhook do Slack para notificacoes de deploy
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx

# ------------------------------------------------------------------------------
# Registry (para CI/CD)
# ------------------------------------------------------------------------------
# REGISTRY=ghcr.io
# IMAGE_NAME=thinkcoffee/thinkcoffee
