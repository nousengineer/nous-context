# ==============================================================================
# ThinkCoffee - Environment Variables
# ==============================================================================
# Copy this file to .env and customize for your environment
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
NODE_ENV=production
THINKCOFFEE_VERSION=latest
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# MCP Server
# ------------------------------------------------------------------------------
MCP_PORT=3000

# ------------------------------------------------------------------------------
# Data Paths (inside container)
# ------------------------------------------------------------------------------
THINKCOFFEE_DATA_DIR=/data
THINKCOFFEE_DB_PATH=/data/data.sqlite
THINKCOFFEE_SNAPSHOT_DIR=/data/snapshots
THINKCOFFEE_LOG_DIR=/data/logs

# ------------------------------------------------------------------------------
# V3 Safety Net Configuration
# ------------------------------------------------------------------------------
# Retention period for snapshots (days)
THINKCOFFEE_SNAPSHOT_RETENTION_DAYS=7

# Maximum size for individual snapshots (MB)
THINKCOFFEE_SNAPSHOT_MAX_SIZE_MB=50

# Enable dry-run mode by default (prevents accidental writes)
THINKCOFFEE_DRY_RUN_DEFAULT=false

# Diff preview mode: 'existing-only' | 'full' | 'none'
THINKCOFFEE_DIFF_PREVIEW_MODE=existing-only

# Command confirmation: 'all' | 'destructive-only' | 'none'
THINKCOFFEE_COMMAND_CONFIRMATION=destructive-only

# ------------------------------------------------------------------------------
# Backup Configuration
# ------------------------------------------------------------------------------
# How many days to keep backups
BACKUP_RETENTION_DAYS=30

# Maximum number of backups to keep
MAX_BACKUP_COUNT=10

# ------------------------------------------------------------------------------
# Monitoring (optional)
# ------------------------------------------------------------------------------
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
