# ==============================================================================
# ThinkBrew - Environment Variables
# Copy to `.env` and adjust as needed. All variables are optional.
# ==============================================================================

# --- Storage ---
# SQLite database location. Defaults to ~/.thinkbrew/data.sqlite
# THINKBREW_DB_PATH=
# Base data directory. Defaults to ~/.thinkbrew
# THINKBREW_DATA_DIR=
# Snapshots / logs directories (used by file tools safety net)
# THINKBREW_SNAPSHOT_DIR=
# THINKBREW_LOG_DIR=
# THINKBREW_SNAPSHOT_RETENTION_DAYS=7
# THINKBREW_SNAPSHOT_MAX_SIZE_MB=100

# --- MCP server workspace sandbox ---
# Restrict file tools to a specific path. Also settable via --workspace=<path>
# THINKBREW_WORKSPACE=

# --- Safety net defaults ---
# THINKBREW_DRY_RUN_DEFAULT=false
# THINKBREW_DIFF_PREVIEW_MODE=always
# THINKBREW_COMMAND_CONFIRMATION=always

# --- Auto-export (sync context -> AI config files) ---
# THINKBREW_AUTO_EXPORT_ENABLED=false
# THINKBREW_AUTO_EXPORT_INTERVAL_MS=30000
# THINKBREW_AUTO_EXPORT_TARGETS=.github/copilot-instructions.md,.cursorrules,CLAUDE.md

# --- Local LLM (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
