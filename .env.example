# ==============================================================================
# Anamnesic - Environment Variables
# Copy to `.env` and adjust as needed. All variables are optional.
# ==============================================================================

# --- Storage ---
# SQLite database location. Defaults to ~/.anamnesic/data.sqlite
# ANAMNESIC_DB_PATH=
# Base data directory. Defaults to ~/.anamnesic
# ANAMNESIC_DATA_DIR=
# Snapshots / logs directories (used by file tools safety net)
# ANAMNESIC_SNAPSHOT_DIR=
# ANAMNESIC_LOG_DIR=
# ANAMNESIC_SNAPSHOT_RETENTION_DAYS=7
# ANAMNESIC_SNAPSHOT_MAX_SIZE_MB=100

# --- MCP server workspace sandbox ---
# Restrict file tools to a specific path. Also settable via --workspace=<path>
# ANAMNESIC_WORKSPACE=

# --- Safety net defaults ---
# ANAMNESIC_DRY_RUN_DEFAULT=false
# ANAMNESIC_DIFF_PREVIEW_MODE=always
# ANAMNESIC_COMMAND_CONFIRMATION=always

# --- Auto-export (sync context -> AI config files) ---
# ANAMNESIC_AUTO_EXPORT_ENABLED=false
# ANAMNESIC_AUTO_EXPORT_INTERVAL_MS=30000
# ANAMNESIC_AUTO_EXPORT_TARGETS=.github/copilot-instructions.md,.cursorrules,CLAUDE.md

# --- Local LLM (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Cloud SaaS (usage metering + sync) ---
# ANAMNESIC_API_URL=https://app.anamnesic.dev
# ANAMNESIC_API_KEY=anamnesic_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
