# ==============================================================================
# ThinkCoffee - Environment Variables Configuration
# ==============================================================================
# Copy this file to .env and fill in the actual values for your environment
# IMPORTANT: Never commit .env to version control
# ==============================================================================

# Application Configuration
# ==============================================================================
NODE_ENV=development
APP_NAME=thinkcoffee
APP_PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=debug
DEBUG=thinkcoffee:*

# Database Configuration - PostgreSQL
# ==============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=thinkcoffee
DB_USER=thinkcoffee_user
DB_PASSWORD=your_secure_password_here_change_in_prod
DATABASE_URL=postgres://thinkcoffee_user:your_secure_password_here_change_in_prod@postgres:5432/thinkcoffee

# Cache Configuration - Redis
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_change_in_prod
REDIS_DB=0
REDIS_URL=redis://:your_redis_password_change_in_prod@redis:6379/0

# JWT Authentication
# ==============================================================================
JWT_SECRET=your_jwt_secret_key_here_must_be_long_and_secure_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_EXPIRY=604800
JWT_ALGORITHM=HS256
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_must_be_long_and_secure
REFRESH_TOKEN_EXPIRES_IN=30d

# Email Configuration - SMTP
# ==============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=noreply@thinkcoffee.com
MAIL_FROM_NAME=ThinkCoffee Team
MAIL_TRANSPORT=smtp

# Cloud Storage - AWS S3 (optional)
# ==============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=thinkcoffee-uploads
AWS_S3_PUBLIC_URL=https://thinkcoffee-uploads.s3.amazonaws.com

# Payment Processing - Stripe (optional)
# ==============================================================================
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_secret_here
STRIPE_CURRENCY=USD

# Authentication Providers (optional)
# ==============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/callback

# Monitoring & Error Tracking (optional)
# ==============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# Analytics (optional)
# ==============================================================================
MIXPANEL_TOKEN=
GOOGLE_ANALYTICS_ID=
AMPLITUDE_API_KEY=

# Feature Flags
# ==============================================================================
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_STRIPE_PAYMENTS=false
ENABLE_SOCIAL_LOGIN=false
ENABLE_S3_UPLOAD=false
FEATURE_NEW_DASHBOARD=false

# Deployment Configuration
# ==============================================================================
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
DEPLOY_HOST=production.thinkcoffee.com
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/thinkcoffee
DEPLOY_KEY_PATH=~/.ssh/deploy_key

# Development Tools (Development only)
# ==============================================================================
PGADMIN_EMAIL=admin@thinkcoffee.local
PGADMIN_PASSWORD=admin
REDIS_COMMANDER_ENABLED=false

# Rate Limiting
# ==============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
# ==============================================================================
SESSION_SECRET=your_session_secret_key_change_in_production
SESSION_TIMEOUT=3600000

# Logging Configuration
# ==============================================================================
LOG_FORMAT=json
LOG_LEVEL_CONSOLE=debug
LOG_LEVEL_FILE=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# API Configuration
# ==============================================================================
API_VERSION=v1
API_PREFIX=/api
MAX_REQUEST_SIZE=10mb
CORS_ORIGIN=http://localhost:3000

# Database Connection Pool
# ==============================================================================
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Performance
# ==============================================================================
NODE_OPTIONS=--max-old-space-size=512
MEMORY_LIMIT=512M
