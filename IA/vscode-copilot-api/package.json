{
  "name": "thinkcoffee-vscode",
  "displayName": "ThinkCoffee",
  "description": "AI Context Management - maintain project context across all AI assistants",
  "version": "1.0.1",
  "publisher": "thinkcoffee",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronokairo/thinkcoffee.git"
  },
  "homepage": "https://github.com/chronokairo/thinkcoffee",
  "bugs": {
    "url": "https://github.com/chronokairo/thinkcoffee/issues"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "thinkcoffee",
          "title": "ThinkCoffee",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "thinkcoffee": [
        {
          "type": "webview",
          "id": "thinkcoffee.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "thinkcoffee.refreshProjects",
        "title": "ThinkCoffee: Refresh Projects"
      },
      {
        "command": "thinkcoffee.createProject",
        "title": "ThinkCoffee: Create Project"
      },
      {
        "command": "thinkcoffee.addContext",
        "title": "ThinkCoffee: Add Context Entry"
      },
      {
        "command": "thinkcoffee.addFileAsContext",
        "title": "ThinkCoffee: Add File as Context"
      },
      {
        "command": "thinkcoffee.addSelectionAsContext",
        "title": "ThinkCoffee: Add Selection as Context"
      },
      {
        "command": "thinkcoffee.addStructureAsContext",
        "title": "ThinkCoffee: Add Workspace Structure as Context"
      },
      {
        "command": "thinkcoffee.addDecision",
        "title": "ThinkCoffee: Record Decision"
      },
      {
        "command": "thinkcoffee.syncContext",
        "title": "ThinkCoffee: Sync to AI Tools"
      },
      {
        "command": "thinkcoffee.exportContext",
        "title": "ThinkCoffee: Export Context"
      },
      {
        "command": "thinkcoffee.openContextFile",
        "title": "ThinkCoffee: Open Context File"
      },
      {
        "command": "thinkcoffee.viewContext",
        "title": "ThinkCoffee: View Context Entry"
      },
      {
        "command": "thinkcoffee.openChat",
        "title": "ThinkCoffee: Open AI Chat"
      },
      {
        "command": "thinkcoffee.createPipeline",
        "title": "ThinkCoffee: Create Pipeline"
      },
      {
        "command": "thinkcoffee.approvePhase",
        "title": "ThinkCoffee: Approve Phase"
      },
      {
        "command": "thinkcoffee.rejectPhase",
        "title": "ThinkCoffee: Reject Phase"
      },
      {
        "command": "thinkcoffee.viewTaskOutput",
        "title": "ThinkCoffee: View Task Output"
      },
      {
        "command": "thinkcoffee.refreshPipeline",
        "title": "ThinkCoffee: Refresh Pipeline"
      },
      {
        "command": "thinkcoffee.openOtherProject",
        "title": "ThinkCoffee: Open Other Project"
      },
      {
        "command": "thinkcoffee.configureAgentModels",
        "title": "ThinkCoffee: Configure Agent Models"
      },
      {
        "command": "thinkcoffee.runPhase",
        "title": "ThinkCoffee: Run Current Phase (Start Agents)"
      },
      {
        "command": "thinkcoffee.stopAgents",
        "title": "ThinkCoffee: Stop All Agents"
      },
      {
        "command": "thinkcoffee.invokeAgent",
        "title": "ThinkCoffee: Invoke Agent"
      },
      {
        "command": "thinkcoffee.viewAgentModels",
        "title": "ThinkCoffee: View Agent Models"
      },
      {
        "command": "thinkcoffee.showHistory",
        "title": "ThinkCoffee: Show Pipeline History",
        "icon": "$(history)"
      },
      {
        "command": "thinkcoffee.backupHistory",
        "title": "ThinkCoffee: Backup Pipeline History"
      },
      {
        "command": "thinkcoffee.restoreHistory",
        "title": "ThinkCoffee: Restore Pipeline History"
      },
      {
        "command": "thinkcoffee.exportHistory",
        "title": "ThinkCoffee: Export Pipeline History"
      },
      {
        "command": "thinkcoffee.toggleDryRun",
        "title": "ThinkCoffee: Toggle Dry-Run Mode",
        "icon": "$(beaker)"
      },
      {
        "command": "thinkcoffee.openSafetyNet",
        "title": "ThinkCoffee: Open Safety Net Panel",
        "icon": "$(shield)"
      },
      {
        "command": "thinkcoffee.rollback",
        "title": "ThinkCoffee: Rollback Phase",
        "icon": "$(discard)"
      },
      {
        "command": "thinkcoffee.listSnapshots",
        "title": "ThinkCoffee: List Available Snapshots"
      },
      {
        "command": "thinkcoffee.cleanupSnapshots",
        "title": "ThinkCoffee: Cleanup Old Snapshots"
      },
      {
        "command": "thinkcoffee.history.refresh",
        "title": "ThinkCoffee: Refresh History",
        "icon": "$(refresh)"
      },
      {
        "command": "thinkcoffee.advancedSoftware.generateCode",
        "title": "ThinkCoffee: Advanced Code Generation",
        "icon": "$(code)"
      },
      {
        "command": "thinkcoffee.advancedSoftware.debugCode",
        "title": "ThinkCoffee: AI-Powered Code Debugging",
        "icon": "$(debug)"
      },
      {
        "command": "thinkcoffee.advancedSoftware.refactorCode",
        "title": "ThinkCoffee: Intelligent Code Refactoring",
        "icon": "$(tools)"
      },
      {
        "command": "thinkcoffee.advancedSecurity.scanVulnerabilities",
        "title": "ThinkCoffee: Comprehensive Security Scan",
        "icon": "$(shield-check)"
      },
      {
        "command": "thinkcoffee.advancedSecurity.simulateAttack",
        "title": "ThinkCoffee: Attack Simulation (Controlled)",
        "icon": "$(warning)"
      },
      {
        "command": "thinkcoffee.advancedSecurity.zeroDayDiscovery",
        "title": "ThinkCoffee: Zero-Day Vulnerability Discovery",
        "icon": "$(search)"
      },
      {
        "command": "thinkcoffee.advancedMultimodal.analyzeImage",
        "title": "ThinkCoffee: AI Image Analysis",
        "icon": "$(file-media)"
      },
      {
        "command": "thinkcoffee.advancedMultimodal.analyzeDiagram",
        "title": "ThinkCoffee: Diagram Interpretation",
        "icon": "$(graph)"
      },
      {
        "command": "thinkcoffee.advancedMultimodal.synthesizeKnowledge",
        "title": "ThinkCoffee: Knowledge Synthesis",
        "icon": "$(book)"
      },
      {
        "command": "thinkcoffee.reasoning.multiStepSolve",
        "title": "ThinkCoffee: Multi-Step Problem Solving",
        "icon": "$(lightbulb)"
      },
      {
        "command": "thinkcoffee.reasoning.adaptiveThink",
        "title": "ThinkCoffee: Adaptive Deep Reasoning",
        "icon": "$(brain)"
      },
      {
        "command": "thinkcoffee.workflow.createComplex",
        "title": "ThinkCoffee: Create Complex Workflow",
        "icon": "$(workflow)"
      },
      {
        "command": "thinkcoffee.workflow.executeAutonomous",
        "title": "ThinkCoffee: Execute Autonomous Workflow",
        "icon": "$(play-circle)"
      },
      {
        "command": "thinkcoffee.orchestrator.showRunStatus",
        "title": "ThinkCoffee: Orchestrator Run Status",
        "icon": "$(pulse)"
      },
      {
        "command": "thinkcoffee.orchestrator.showCheckpoints",
        "title": "ThinkCoffee: Orchestrator Checkpoints",
        "icon": "$(list-unordered)"
      },
      {
        "command": "thinkcoffee.orchestrator.pauseRun",
        "title": "ThinkCoffee: Pause Orchestrator Run",
        "icon": "$(debug-pause)"
      },
      {
        "command": "thinkcoffee.orchestrator.resumeRun",
        "title": "ThinkCoffee: Resume Orchestrator Run",
        "icon": "$(debug-start)"
      },
      {
        "command": "thinkcoffee.orchestrator.selectRun",
        "title": "ThinkCoffee: Select Orchestrator Run",
        "icon": "$(symbol-key)"
      },
      {
        "command": "thinkcoffee.openAdvancedAgents",
        "title": "ThinkCoffee: Open Advanced AI Agents Panel",
        "icon": "$(robot)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "thinkcoffee.addSelectionAsContext",
          "when": "editorHasSelection",
          "group": "thinkcoffee"
        },
        {
          "command": "thinkcoffee.addFileAsContext",
          "group": "thinkcoffee"
        }
      ],
      "explorer/context": [
        {
          "command": "thinkcoffee.addFileAsContext",
          "when": "!explorerResourceIsFolder",
          "group": "thinkcoffee"
        }
      ],
      "view/title": [],
      "view/item/context": []
    },
    "configuration": {
      "title": "ThinkCoffee",
      "properties": {
        "thinkcoffee.diffPreview": {
          "type": "string",
          "enum": [
            "always",
            "existing-only",
            "never"
          ],
          "default": "existing-only",
          "description": "When to show diff preview before write_file operations.",
          "enumDescriptions": [
            "Always show diff preview for all file writes",
            "Show diff preview only for existing files (default)",
            "Never show diff preview, write files directly"
          ]
        },
        "thinkcoffee.commandConfirmation": {
          "type": "string",
          "enum": [
            "always",
            "destructive-only",
            "never"
          ],
          "default": "destructive-only",
          "description": "When to ask for confirmation before running shell commands.",
          "enumDescriptions": [
            "Always ask for confirmation before running any command",
            "Ask confirmation only for destructive commands (default)",
            "Never ask for confirmation, run commands directly"
          ]
        },
        "thinkcoffee.safetynet.autoCleanup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically cleanup old snapshots on extension activation."
        },
        "thinkcoffee.safetynet.retentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Number of days to retain snapshots before automatic cleanup."
        },
        "thinkcoffee.safetynet.maxSizeMB": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum total size in MB for snapshots per pipeline."
        },
        "thinkcoffee.orchestrator.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for ThinkCoffee orchestrator API (example: http://localhost:3000)."
        },
        "thinkcoffee.orchestrator.token": {
          "type": "string",
          "default": "",
          "description": "Bearer token for orchestrator API authentication."
        },
        "thinkcoffee.orchestrator.workspaceId": {
          "type": "string",
          "default": "",
          "description": "Workspace ID used by remote orchestrator. If empty, derives from current folder name."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsc --watch",
    "package": "node esbuild.js && pnpm exec vsce package --no-dependencies",
    "publish:vsce": "pnpm exec vsce publish",
    "vscode:prepublish": "node esbuild.js"
  },
  "devDependencies": {
    "@thinkcoffee/core": "workspace:*",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.6"
  }
}