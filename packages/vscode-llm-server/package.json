{
    "name": "vscode-llm-server",
    "displayName": "VS Code LLM Server",
    "description": "Exposes VS Code LLMs via an Ollama-compatible HTTP API (ip:port)",
    "version": "0.1.0",
    "publisher": "thinkcoffee",
    "repository": {
        "type": "git",
        "url": "https://github.com/chronokairo/thinkcoffee.git"
    },
    "engines": {
        "vscode": "^1.90.0",
        "node": ">=18"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "llm",
        "ollama",
        "api",
        "copilot",
        "lm"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "vscode-llm-server.start",
                "title": "LLM Server: Start"
            },
            {
                "command": "vscode-llm-server.stop",
                "title": "LLM Server: Stop"
            },
            {
                "command": "vscode-llm-server.status",
                "title": "LLM Server: Show Status"
            },
            {
                "command": "vscode-llm-server.listModels",
                "title": "LLM Server: List Available Models"
            }
        ],
        "configuration": {
            "title": "VS Code LLM Server",
            "properties": {
                "vscode-llm-server.host": {
                    "type": "string",
                    "default": "127.0.0.1",
                    "description": "Host address to bind the server to. Use '0.0.0.0' to listen on all interfaces (not recommended)."
                },
                "vscode-llm-server.port": {
                    "type": "number",
                    "default": 11434,
                    "minimum": 1024,
                    "maximum": 65535,
                    "description": "Port number for the Ollama-compatible API server."
                },
                "vscode-llm-server.autoStart": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically start the server when VS Code opens."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node esbuild.js",
        "build": "node esbuild.js",
        "compile": "tsc --noEmit",
        "package": "pnpm exec vsce package --no-dependencies"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.90.0",
        "@vscode/vsce": "^2.24.0",
        "esbuild": "^0.20.0",
        "typescript": "^5.4.0"
    }
}