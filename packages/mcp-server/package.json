{
  "name": "@thinkcoffee/mcp-server",
  "version": "1.0.0",
  "description": "ThinkCoffee MCP Server - AI context management via Model Context Protocol",
  "main": "dist/index.js",
  "bin": {
    "thinkcoffee-mcp": "dist/index.js",
    "thinkcoffee-api": "dist/start-api.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:api": "node dist/start-api.js",
    "dev:api": "npx tsx src/start-api.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@thinkcoffee/core": "workspace:*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "hono": "^4.12.10",
    "jsonwebtoken": "^9.0.3",
    "typeorm": "^0.3.19",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.39",
    "tsx": "^4.7.0",
    "typescript": "^5.1.6"
  }
}
