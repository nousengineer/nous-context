# ThinkCoffee Production Environment Configuration
# Copy this file to .env.production and configure for your environment

# === Application ===
NODE_ENV=production
LOG_LEVEL=info
PORT=3000
API_URL=https://api.thinkcoffee.dev

# === Database ===
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=thinkcoffee
DB_USER=thinkcoffee
DB_PASSWORD=your-strong-db-password-change-me
DB_SSL=true
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=10000

# === Redis Cache ===
REDIS_URL=redis://:your-redis-password@redis:6379
REDIS_PASSWORD=your-redis-password-change-me
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=5000

# === Authentication ===
JWT_SECRET=your-very-secure-jwt-secret-key-minimum-32-characters-long
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me
JWT_REFRESH_EXPIRY=30d

# === AI Providers ===
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# OpenAI (GPT)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# Primary AI provider (anthropic, openai, ollama)
AI_PROVIDER=anthropic

# === Security ===
# Enable CORS
CORS_ORIGIN=https://app.thinkcoffee.dev
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_KEY_PREFIX=rl:

# HTTPS/SSL
HTTPS_ENABLED=true
SSL_KEY_PATH=/etc/nginx/certs/key.pem
SSL_CERT_PATH=/etc/nginx/certs/cert.pem

# Security headers
SECURITY_HEADERS=true
X_FRAME_OPTIONS=SAMEORIGIN
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block

# === File Storage ===
STORAGE_TYPE=local
STORAGE_PATH=/app/uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,json,csv,xlsx,png,jpg,jpeg,gif

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=thinkcoffee-uploads

# === Email (Optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@thinkcoffee.dev
SMTP_USE_TLS=true

# === Logging ===
LOG_FORMAT=json
LOG_OUTPUT=console,file
LOG_FILE_PATH=/app/logs/thinkcoffee.log
LOG_FILE_MAX_SIZE=10M
LOG_FILE_MAX_FILES=10
LOG_LEVEL_API=info
LOG_LEVEL_DB=warn
LOG_LEVEL_SECURITY=info

# === Monitoring ===
# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_ENDPOINT=/metrics

# Health check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000  # 30 seconds

# === Database Backups ===
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups

# === Session Management ===
SESSION_SECRET=your-session-secret-key-change-me
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=Strict

# === Feature Flags ===
FEATURE_ADVANCED_SECURITY=true
FEATURE_MULTIMODAL_ANALYSIS=true
FEATURE_WORKFLOW_EXECUTION=true
FEATURE_CODE_GENERATION=true
FEATURE_VULNERABILITY_DISCOVERY=true

# === External Services ===
# GitHub Integration
GITHUB_TOKEN=ghp_your-github-token-here

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#deployments
SLACK_MENTIONS=@devops-team

# === Development/Debug ===
DEBUG=false
DEBUG_SQL=false
VERBOSE_LOGGING=false

# === Third-party Services ===
# Sentry (Error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog (APM)
DD_API_KEY=your-datadog-api-key
DD_ENABLED=false
DD_ENV=production
DD_SERVICE=thinkcoffee-api

# === Compliance & Security ===
# GDPR/Privacy
GDPR_ENABLED=true
DATA_RETENTION_DAYS=365
PII_ENCRYPTION_ENABLED=true
AUDIT_LOG_ENABLED=true

# === Limits & Quotas ===
MAX_REQUEST_SIZE=104857600  # 100MB
EXECUTION_TIMEOUT=300000  # 5 minutes
MAX_CONCURRENT_TASKS=10
MAX_AGENTS_PER_USER=100

# === Notification Settings ===
EMAIL_NOTIFICATIONS_ENABLED=true
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# === API Versioning ===
API_VERSION=v1
API_DEPRECATION_ENABLED=true

# === Performance ===
QUERY_CACHE_TTL=3600
CONNECTION_POOL_SIZE=20
ENABLE_QUERY_OPTIMIZATION=true
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
