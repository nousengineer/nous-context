# ==============================================================================
# ThinkBrew - Test Environment Variables
# ==============================================================================
NODE_ENV=test
LOG_LEVEL=error
THINKBREW_DB_PATH=:memory:
THINKBREW_DATA_DIR=/tmp/thinkbrew-test
THINKBREW_SNAPSHOT_DIR=/tmp/thinkbrew-test/snapshots
THINKBREW_LOG_DIR=/tmp/thinkbrew-test/logs
THINKBREW_SNAPSHOT_RETENTION_DAYS=1
THINKBREW_SNAPSHOT_MAX_SIZE_MB=10
THINKBREW_DRY_RUN_DEFAULT=true
THINKBREW_DIFF_PREVIEW_MODE=never
THINKBREW_COMMAND_CONFIRMATION=never
THINKBREW_AUTO_EXPORT_ENABLED=false
THINKBREW_AUTO_EXPORT_INTERVAL_MS=1000
THINKBREW_AUTO_EXPORT_TARGETS=.github/copilot-instructions.md,.cursorrules
