# ==============================================================================
# ThinkCoffee - .dockerignore (V4)
# ==============================================================================
# Keeps Docker build context lean for fast builds.
# ==============================================================================

# Version control
.git/
.gitignore

# Dependencies (rebuilt in container)
node_modules/
**/node_modules/

# Build outputs (rebuilt in container)
**/dist/

# VS Code extension (not needed in server/CLI containers)
packages/vscode/
*.vsix

# Environment files (secrets -- never bake into image)
.env
.env.*
!.env.example

# Test and coverage artifacts
coverage/
*.test.ts
*.spec.ts
**/__tests__/

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Docs and meta (not needed at runtime)
docs/
*.md
!README.md
LICENSE

# Monitoring configs (separate compose file)
monitoring/

# Backup files
backups/

# CI/CD configs
.github/

# Build artifacts
*.tsbuildinfo
*.log
